# App environment: development | production
APP_ENV=development

# Fintoc API
FINTOC_API_KEY=
FINTOC_PRIVATE_KEY_PATH=

# Fintoc Webhooks
# production: FINTOC_WEBHOOK_SECRET is REQUIRED (server will refuse to start without it)
# development: if empty, signature validation is skipped and a simulated webhook poller runs
FINTOC_WEBHOOK_SECRET=
FINTOC_WEBHOOK_URL=

# Celery (set automatically by docker-compose, override here for local dev)
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1
